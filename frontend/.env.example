# =====================================================================
# FlexVer · Frontend · Plantilla de variables de entorno (Vite)
# Copia este archivo a `.env` y reemplaza los placeholders.
# Solo las variables con prefijo VITE_ se exponen al cliente.
# NUNCA pongas aquí la service_role key de Supabase (es solo del backend).
# =====================================================================

# --- Supabase ---
# Misma URL que SUPABASE_URL en el backend.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
# Usa la ANON key (pública, segura para el cliente). Aquí NO va la service key.
VITE_SUPABASE_ANON_KEY=tu-anon-key

# --- API backend ---
VITE_API_URL=http://localhost:8000

# --- Mapbox ---
VITE_MAPBOX_TOKEN=pk.tu-token-mapbox

# --- Cloudflare Turnstile (anti-bot) ---
# Site Key PÚBLICA del widget. Si se omite, el código usa la clave de pruebas
# de Cloudflare (1x00000000000000000000AA) que siempre aprueba el desafío.
# La Secret Key correspondiente se valida en el BACKEND, nunca aquí.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
