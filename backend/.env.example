# --- Supabase ---
# URL base del proyecto (la misma que usa el frontend en VITE_SUPABASE_URL)
SUPABASE_URL=https://tu-proyecto.supabase.co
# Key del backend. Recomendado: service_role (server-side, NO exponer al cliente).
# Si quieres respetar las políticas RLS desde el backend, usa la anon key.
SUPABASE_KEY=tu-supabase-key
