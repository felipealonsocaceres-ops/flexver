# =====================================================================
# FlexVer · Backend · Plantilla de variables de entorno
# Copia este archivo a `.env` y reemplaza los placeholders.
# El `.env` real está en .gitignore: NUNCA lo subas al repo.
# =====================================================================

# --- Supabase ---
# URL base del proyecto (la misma que usa el frontend en VITE_SUPABASE_URL).
SUPABASE_URL=https://tu-proyecto.supabase.co

# CRÍTICO: el backend usa UN SOLO cliente con esta key, y debe ser la
# service_role key (formato JWT `service_role`, o la nueva `sb_secret_...`).
# Es obligatoria para que funcionen:
#   - la subida/borrado en el bucket PRIVADO de KYC (bypass de RLS), y
#   - la inserción de consentimientos.
# Con la anon key estas operaciones fallan por RLS. NO la expongas al cliente.
SUPABASE_KEY=tu-service-role-key

# --- Mapbox ---
# Token de acceso para geocoding/rutas en el backend.
MAPBOX_ACCESS_TOKEN=pk.tu-token-mapbox

# --- Frontend ---
# URL base del frontend, usada para CORS y redirects.
FRONTEND_URL=http://localhost:5173

# --- Transbank Webpay Plus ---
# Valores por defecto = ambiente de integración (sandbox).
# En producción reemplaza por las credenciales reales y AMBIENTE=production.
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
TRANSBANK_AMBIENTE=integration

# --- Redis / Celery (telemetría) ---
# Broker/result backend para las tareas de Celery. Opcional en local si no
# corres el worker de telemetría; por defecto apunta a un Redis local.
REDIS_URL=redis://localhost:6379/0
